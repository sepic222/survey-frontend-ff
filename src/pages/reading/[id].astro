---
import FateFlixSurvey from "../../components/FateFlixSurvey.jsx";
const { id } = Astro.params;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Your Cosmic Reading | FateFlix</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@600&family=Bebas+Neue&family=Nunito:ital,wght@0,900;1,900&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-black min-h-screen">
    <FateFlixSurvey client:only="react" initialSubmissionId={id} />
  </body>
</html>

